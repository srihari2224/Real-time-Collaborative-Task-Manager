{
  "name": "taskflow-backend",
  "version": "1.0.0",
  "description": "TaskFlow — Real-time Collaborative Task Manager Backend (Fastify + TypeScript + PostgreSQL + Redis + S3)",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build":      "tsc --project tsconfig.json",
    "start":      "node dist/server.js",
    "dev":        "tsx watch src/server.ts",
    "format":     "prettier --write \"src/**/*.ts\"",
    "lint":       "eslint src/ --ext .ts",
    "lint:fix":   "eslint src/ --ext .ts --fix",
    "db:migrate": "tsx src/models/migrate.ts",
    "db:seed":    "tsx src/models/seed.ts",
    "test":       "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3":           "^3.540.0",
    "@aws-sdk/client-ses":          "^3.540.0",
    "@aws-sdk/s3-request-presigner":"^3.540.0",
    "@fastify/cors":                "^9.0.1",
    "@fastify/helmet":              "^11.1.1",
    "@fastify/multipart":           "^8.1.0",
    "@fastify/rate-limit":          "^9.1.0",
    "@fastify/websocket":           "^10.0.1",
    "@supabase/supabase-js":        "^2.42.5",
    "bull":                         "^4.12.4",
    "dotenv":                       "^16.4.5",
    "fastify":                      "^4.26.2",
    "ioredis":                      "^5.3.2",
    "joi":                          "^17.12.3",
    "jsonwebtoken":                 "^9.0.2",
    "pg":                           "^8.11.5",
    "pino":                         "^9.0.0",
    "pino-pretty":                  "^11.0.0",
    "socket.io":                    "^4.7.5",
    "uuid":                         "^9.0.1",
    "zod":                          "^3.22.4"
  },
  "devDependencies": {
    "@types/node":                  "^20.12.7",
    "@types/pg":                    "^8.11.5",
    "@types/jsonwebtoken":          "^9.0.6",
    "@types/uuid":                  "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser":    "^7.0.0",
    "eslint":                       "^9.1.1",
    "jest":                         "^29.7.0",
    "prettier":                     "^3.2.5",
    "tsx":                          "^4.7.0",
    "typescript":                   "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
