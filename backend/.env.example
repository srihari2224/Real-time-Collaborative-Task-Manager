# ============================================================
#  TaskFlow Backend — Environment Variables Template
#  Copy this file to .env and fill in your actual values
# ============================================================

# Server
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
API_VERSION=v1

# Supabase (PostgreSQL + Auth)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct PostgreSQL Connection (for pg pool)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=true

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_DB=0

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=taskflow-files
S3_BUCKET_URL=https://taskflow-files.s3.amazonaws.com
S3_PRESIGNED_URL_EXPIRY=3600

# AWS SES (Email)
SES_FROM_EMAIL=noreply@taskflow.app
SES_FROM_NAME=TaskFlow
SES_REGION=us-east-1

# JWT (for custom tokens if needed)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://taskflow.app

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# WebSocket
WS_CORS_ORIGIN=http://localhost:3000

# Bull Queue (Redis-backed)
BULL_REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# File Upload Limits
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/zip
